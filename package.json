{
  "name": "handsontable-root",
  "private": true,
  "description": "Handsontable is a JavaScript Data Grid available for React, Angular and Vue.",
  "homepage": "https://handsontable.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/handsontable/handsontable.git"
  },
  "bugs": {
    "url": "https://github.com/handsontable/handsontable/issues"
  },
  "author": "Handsoncode <hello@handsontable.com>",
  "scripts": {
    "in": "cross-env-shell COMMAND_ENV=in node scripts/translate-to-native-npm.mjs",
    "all": "cross-env-shell COMMAND_ENV=all node scripts/translate-to-native-npm.mjs",
    "clean:node_modules": "node ./scripts/clean-node-modules.mjs",
    "lint": "npm run eslint && npm run all lint -- --if-present && npm run lint --prefix performance-tests",
    "eslint": "eslint .github/scripts/ bin/changelog scripts/",
    "test": "npm run all test -- -e=examples",
    "build": "npm run all build -- -e=examples",
    "freeze": "node scripts/freeze.mjs",
    "release": "node scripts/release.mjs",
    "changelog": "bin/changelog",
    "sync-skills": "node scripts/sync-skills-to-cursor.mjs",
    "publish-all": "npm run all publish-package -- -e=examples",
    "pre-release": "node scripts/pre-release.mjs && npm run all build -- -e=examples visual-tests && npm run publish-all --tag experimental",
    "examples:version": "node examples/scripts/code-examples.mjs version",
    "examples:install": "node examples/scripts/code-examples.mjs install",
    "examples:build": "node examples/scripts/code-examples.mjs build",
    "examples:test": "node examples/scripts/code-examples.mjs test",
    "examples:start": "http-server ./examples/tmp"
  },
  "devDependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "@angular/compiler": "^19.2.16",
    "@babel/cli": "^7.8.3",
    "@babel/core": "^7.11.4",
    "@babel/eslint-parser": "^7.13.14",
    "@babel/eslint-plugin": "^7.13.16",
    "@babel/plugin-proposal-class-properties": "^7.8.3",
    "@babel/plugin-proposal-object-rest-spread": "^7.11.0",
    "@babel/plugin-syntax-import-assertions": "^7.16.7",
    "@babel/plugin-syntax-jsx": "^7.24.7",
    "@babel/plugin-transform-runtime": "^7.11.0",
    "@babel/preset-env": "^7.11.0",
    "@babel/register": "^7.8.3",
    "@babel/runtime": "^7.11.2",
    "@babel/types": "^7.12.12",
    "babel-plugin-forbidden-imports": "^0.1.2",
    "babel-plugin-transform-inline-environment-variables": "^0.4.3",
    "babel-plugin-transform-require-ignore": "^0.1.1",
    "chalk": "^4.1.2",
    "core-js": "^3.37.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^46.0.0",
    "execa": "^5.0.0",
    "fs-extra": "^4.0.2",
    "glob": "^7.1.2",
    "global-jsdom": "^24.0.0",
    "inquirer": "^7.3.3",
    "jsdom": "24.0.0",
    "lodash": "^4.17.21",
    "moment": "2.29.4",
    "replace-in-file": "^6.1.0",
    "rimraf": "^3.0.2",
    "semver": "^5.7.1",
    "yargs": "^16.2.0"
  },
  "pnpm": {
    "overrides": {
      "generic-names@1>loader-utils": "^2.0.0",
      "handsontable": "workspace:^",
      "convict": "^6.2.5",
      "handlebars": "^4.7.9",
      "@angular/common": "^19.2.20",
      "@angular/core": "^19.2.20",
      "@angular/compiler": "^19.2.20",
      "nx>minimatch": "^3.1.4",
      "postcss-url>minimatch": "^3.1.4",
      "@typescript-eslint/typescript-estree>minimatch": "^9.0.7",
      "node-forge": "^1.4.0",
      "path-to-regexp": "^0.1.13",
      "anymatch>picomatch": "^2.3.2",
      "readdirp>picomatch": "^2.3.2",
      "micromatch>picomatch": "^2.3.2",
      "jest-util>picomatch": "^2.3.2",
      "@angular-devkit/build-angular>picomatch": "^2.3.2",
      "@angular-devkit/core>picomatch": "^2.3.2",
      "@parcel/watcher>picomatch": "^4.0.4",
      "@rollup/pluginutils>picomatch": "^4.0.4",
      "serialize-javascript": "^7.0.3",
      "pacote>tar": "^7.5.11",
      "node-gyp>tar": "^7.5.11",
      "cacache>tar": "^7.5.11",
      "undici": "^6.24.0",
      "react-star-rating-component>react": "18.3.1",
      "@astrojs/mdx": "^6.0.1"
    },
    "auditConfig": {
      "ignoreCves": [
        "CVE-2023-30533",
        "CVE-2024-22363"
      ]
    }
  },
  "license": "SEE LICENSE IN LICENSE.txt",
  "resolutions": {
    "@babel/core": "^7.11.4"
  },
  "workspaces": [
    "handsontable",
    "wrappers/*",
    "visual-tests",
    "examples",
    "docs"
  ],
  "packageManager": "pnpm@10.30.2"
}
