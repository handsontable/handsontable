{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "allowJs": true
  },
  "include": ["scenarios/**/*.ts", "lib/**/*.mjs", "playwright.config.ts"],
  "exclude": ["node_modules", "output", "golden", "fixtures"]
}
