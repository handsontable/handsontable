---
/**
 * Starlight Head component override.
 *
 * Imports the example runner script, which scans each page for
 * [data-example-js] / [data-example-jsx] elements and dynamically loads
 * the matching Handsontable example modules.
 */
import Default from '@astrojs/starlight/components/Head.astro';
---

<Default {...Astro.props} />

<link rel="icon" media="(prefers-color-scheme: light)" href="/docs/img/favicon.png" />
<link rel="icon" media="(prefers-color-scheme: dark)" href="/docs/img/favicon-dark.png" />

<script is:inline>
  // Remove Starlight's default favicon in favor of light/dark media-query versions above.
  document.querySelector('link[rel="shortcut icon"]')?.remove();
</script>

<script>
  import Handsontable from 'handsontable/base';

  (window as any).HandsontableVersion = Handsontable.version;
  (window as any).HandsontableBuildDate = Handsontable.buildDate;
</script>

<script>
  import '../scripts/example-runner';
</script>

<script>
  // Code block copy button: swap icon to checkmark after copying (matches Copy Markdown UX).
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.expressive-code .copy button');
    if (!btn) return;
    btn.classList.add('copied');
    setTimeout(() => btn.classList.remove('copied'), 3000);
  });
</script>

<script>
  // Move source-code-link elements inside their preceding heading for
  // absolute positioning. The preprocessor emits them as standalone <a> tags
  // (wrapped in <p> by Astro), but CSS absolute positioning requires a
  // parent–child relationship.
  document.querySelectorAll<HTMLAnchorElement>('.source-code-link').forEach((link) => {
    const p = link.parentElement;
    if (!p || p.tagName !== 'P') return;
    const heading = p.previousElementSibling;
    if (!heading || !/^H[2-4]$/.test(heading.tagName)) return;
    heading.appendChild(link);
    p.remove();
  });
</script>

<script is:inline>
  /**
   * Algolia crawler compatibility shim.
   *
   * The Algolia crawler config targets legacy VuePress CSS selectors. This
   * script patches the rendered DOM so those selectors match the equivalent
   * Astro Starlight elements without requiring any changes to the crawler config.
   *
   * Selector mapping (VuePress → Astro Starlight):
   *   .content__default              → .sl-markdown-content (class added below)
   *   .sidebar-links .active         → .sidebar-pane a[aria-current="page"]
   *   p.sidebar-heading.open         → .sidebar-pane details[open] summary .large
   */
  document.addEventListener('DOMContentLoaded', function () {
    // 1. Add content__default to the main markdown content wrapper so the
    //    Algolia selectors ".content__default p", ".content__default h2", etc. match.
    var content = document.querySelector('.sl-markdown-content');
    if (content) {
      content.classList.add('content__default');
    }

    // 2. Mark the active sidebar link with the legacy "active" class and its
    //    parent <ul> with the legacy "sidebar-links" class.
    var sidebarPane = document.querySelector('.sidebar-pane');
    if (sidebarPane) {
      var activeLink = sidebarPane.querySelector('a[aria-current="page"]');
      if (activeLink) {
        activeLink.classList.add('active');
        var parentUl = activeLink.closest('ul');
        if (parentUl) {
          parentUl.classList.add('sidebar-links');
        }
      }

      // 3. Inject a visually-hidden <p class="sidebar-heading open"> containing
      //    the current section title so the Algolia lvl0 selector matches.
      //    Starlight marks expanded groups with the HTML "open" attribute on
      //    <details>, so we read the heading text from the open group that
      //    contains the active page.
      var openSummaryText = sidebarPane.querySelector('details[open] summary .large');
      if (openSummaryText) {
        var p = document.createElement('p');
        p.className = 'sidebar-heading open';
        p.textContent = (openSummaryText.textContent || '').trim();
        p.setAttribute('aria-hidden', 'true');
        p.style.cssText = 'position:absolute;left:-9999px;width:0;height:0;overflow:hidden;';
        sidebarPane.insertBefore(p, sidebarPane.firstChild);
      }
    }
  });
</script>
