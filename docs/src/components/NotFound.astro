---
/**
 * Custom 404 page content.
 *
 * This component is rendered inside Starlight's built-in 404 route
 * (node_modules/@astrojs/starlight/routes/static/404.astro), which
 * already provides the StarlightPage shell (header, footer, no sidebar).
 * Placing custom content here avoids the duplicate-route collision that
 * occurs when src/pages/404.astro shadows Starlight's own static route.
 */
---

<div class="not-found">
  <div class="not-found__grid">
    <div class="not-found__code">404</div>
    <div class="not-found__message">
      <p class="not-found__text">
        The page you are looking for does not exist or has been moved.
      </p>
      <a href="/docs/javascript-data-grid/" class="not-found__link">
        Go to documentation home
      </a>
    </div>
  </div>
</div>

<style>
  .not-found {
    padding: 4rem 0;
  }

  .not-found__grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0;
    border: 1px solid var(--sl-color-gray-5);
    max-width: 640px;
  }

  .not-found__code {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
    font-weight: 700;
    color: var(--sl-color-accent);
    padding: 2rem 2.5rem;
    border-right: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-gray-7, var(--sl-color-gray-6));
    line-height: 1;
    min-width: 8rem;
  }

  .not-found__message {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
  }

  .not-found__text {
    color: var(--sl-color-gray-2);
    margin: 0;
    font-size: var(--sl-text-sm);
  }

  .not-found__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--sl-color-accent);
    font-size: var(--sl-text-sm);
    font-weight: 500;
    text-decoration: none;
    border: 1px solid var(--sl-color-accent);
    padding: 0.4rem 0.875rem;
    transition: background-color 0.15s, color 0.15s;
    align-self: flex-start;
  }

  .not-found__link:hover {
    background: var(--sl-color-accent);
    color: var(--sl-color-black);
  }

  @media (max-width: 36rem) {
    .not-found__grid {
      grid-template-columns: 1fr;
    }

    .not-found__code {
      border-right: none;
      border-bottom: 1px solid var(--sl-color-gray-5);
      padding: 1.5rem;
      font-size: 3rem;
    }
  }
</style>
