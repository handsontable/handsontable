---
/**
 * Page footer override.
 *
 * Renders:
 *  1. Starlight's built-in edit-link and prev/next pagination (preserved).
 *  2. A footer bar with social icons, site links, and a live status dot.
 *  3. A copyright line.
 *
 * The status indicator color is fetched from the Statuspage API at render
 * time. If the network is unavailable it falls back to gray.
 */
import EditLink from 'virtual:starlight/components/EditLink';
import Pagination from 'virtual:starlight/components/Pagination';

// ── Status dot ────────────────────────────────────────────────────────────────
// Statuspage public API: indicator is "none" | "minor" | "major" | "critical".
type StatusIndicator = 'none' | 'minor' | 'major' | 'critical' | 'unknown';

let statusIndicator: StatusIndicator = 'unknown';

try {
  const res = await fetch('https://status.handsontable.com/api/v2/status.json');
  if (res.ok) {
    const data = await res.json();
    statusIndicator = data?.status?.indicator ?? 'unknown';
  }
} catch {
  // Network unavailable — show neutral dot
}

const STATUS_COLORS: Record<StatusIndicator, string> = {
  none: '#37bc6c',      // green  — all systems operational
  minor: '#f4a623',     // yellow — minor incident
  major: '#e74c3c',     // red    — major incident
  critical: '#c0392b',  // dark red — critical incident
  unknown: '#8e99a4',   // gray   — could not determine
};

const statusColor = STATUS_COLORS[statusIndicator];

const year = new Date().getFullYear();
---

<!-- Starlight built-ins: edit link + prev/next navigation -->
<div class="sl-footer-built-ins">
  <EditLink {...Astro.props} />
  <Pagination {...Astro.props} />
</div>

<!-- Custom footer bar -->
<footer class="hot-footer">
  <div class="hot-footer__inner">

    <div class="hot-footer__links">
      <!-- Social icons -->
      <div class="hot-footer__social">
        <a
          href="https://github.com/handsontable/handsontable"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="hot-footer__icon-link"
        >
          <svg aria-hidden="true" width="18" height="18" viewBox="0 0 16 16" fill="currentColor">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
        </a>
        <a
          href="https://www.linkedin.com/company/handsontable/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="hot-footer__icon-link"
        >
          <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a
          href="https://twitter.com/handsontable"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="X (Twitter)"
          class="hot-footer__icon-link"
        >
          <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.747l7.73-8.835L1.254 2.25H8.08l4.259 5.631 5.905-5.631zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
      </div>

      <!-- Site links -->
      <nav class="hot-footer__nav" aria-label="Footer navigation">
        <a href="https://handsontable.com/privacy">Privacy policy</a>
        <a href="https://handsontable.com/terms-of-use">Terms of use</a>
        <a href="https://handsontable.com/team">Team</a>
        <a href="https://handsontable.com/contact?category=technical_support">Contact</a>
        <a href="https://handsontable.com/blog/">Blog</a>
        <a href="https://handsontable.com/pricing">Pricing</a>
        <a
          href="https://status.handsontable.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="hot-footer__status-link"
        >
          <span
            class="hot-footer__status-dot"
            style={`background-color: ${statusColor};`}
            aria-hidden="true"
          ></span>
          Status
        </a>
      </nav>
    </div>

    <div class="hot-footer__copyright">
      <p>© 2012 – {year} Handsoncode</p>
    </div>

  </div>
</footer>

<style>
  /* ── Starlight built-ins wrapper ─────────────────────────────────────────── */
  .sl-footer-built-ins {
    /* Matches Starlight's default footer padding so edit/pagination render
       exactly where they would without the override. */
    margin-block-end: 0;
  }

  /* ── Footer bar ──────────────────────────────────────────────────────────── */
  .hot-footer {
    border-top: 1px solid var(--sl-color-hairline-light);
    margin-block-start: 3rem;
    padding-block: 2rem;
  }

  .hot-footer__inner {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* ── Links row ───────────────────────────────────────────────────────────── */
  .hot-footer__links {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  /* ── Social icons ────────────────────────────────────────────────────────── */
  .hot-footer__social {
    align-items: center;
    display: flex;
    gap: 0.75rem;
  }

  .hot-footer__icon-link {
    align-items: center;
    border-radius: 4px;
    color: var(--sl-color-text-accent);
    display: inline-flex;
    padding: 0.15rem;
    transition: color 0.15s, transform 0.15s;
  }

  .hot-footer__icon-link:hover {
    color: var(--sl-color-accent);
    transform: translateY(-1px);
  }

  /* Divider between social icons and text links */
  .hot-footer__social::after {
    border-inline-end: 1px solid var(--sl-color-hairline-light);
    content: '';
    height: 1.25rem;
    margin-inline-start: 0.25rem;
  }

  /* ── Text nav links ──────────────────────────────────────────────────────── */
  .hot-footer__nav {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.1rem;
  }

  .hot-footer__nav a {
    border-radius: 4px;
    color: var(--sl-color-text-accent);
    font-size: var(--sl-text-xs);
    padding: 0.2rem 0.5rem;
    text-decoration: none;
    transition: color 0.15s, background-color 0.15s;
    white-space: nowrap;
  }

  .hot-footer__nav a:hover {
    color: var(--sl-color-accent);
    background-color: var(--sl-color-accent-low);
  }

  /* ── Status link & dot ───────────────────────────────────────────────────── */
  .hot-footer__status-link {
    align-items: center;
    display: inline-flex !important;
    gap: 0.35rem;
  }

  .hot-footer__status-dot {
    border-radius: 50%;
    display: inline-block;
    flex-shrink: 0;
    height: 0.5rem;
    width: 0.5rem;
  }

  /* ── Copyright ───────────────────────────────────────────────────────────── */
  .hot-footer__copyright {
    color: var(--sl-color-gray-3);
    font-size: var(--sl-text-xs);
  }

  .hot-footer__copyright p {
    margin: 0;
  }
</style>
