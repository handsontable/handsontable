---
/**
 * Starlight Header component override.
 *
 * Extends the default header with framework-aware navigation links (Guides,
 * Recipes, API, Changelog), a Support dropdown, a versions dropdown, a
 * Headway changelog widget, and a GitHub stars badge.
 */
import config from 'virtual:starlight/user-config';
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';
import VersionsDropdown from './VersionsDropdown.astro';
import SupportDropdown from './SupportDropdown.astro';

const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const pathname = Astro.url.pathname;

const currentPrefix = pathname.includes('/react-data-grid/')
  ? 'react-data-grid'
  : pathname.includes('/angular-data-grid/')
    ? 'angular-data-grid'
    : 'javascript-data-grid';

const guidesUrl = `/docs/${currentPrefix}/`;
const recipesUrl = `/docs/${currentPrefix}/recipes/`;
const apiUrl = `/docs/${currentPrefix}/api/`;
const changelogUrl = `/docs/${currentPrefix}/changelog/`;
const isApiPage = pathname.includes('/api/');
const isRecipesPage = pathname.includes('/recipes/');
const isChangelogPage = pathname.includes('/changelog/');
const isGuidesPage = !isApiPage && !isRecipesPage && !isChangelogPage;
---

<div class="header sl-flex">
  <div class="title-wrapper sl-flex">
    <SiteTitle />
  </div>
  <div class="sl-flex print:hidden">
    {shouldRenderSearch && <Search />}
  </div>
  <div class="sl-hidden md:sl-flex print:hidden right-group">
    <VersionsDropdown />
    <a
      href={guidesUrl}
      class:list={['nav-link', { 'nav-link--active': isGuidesPage }]}
      aria-current={isGuidesPage ? 'page' : undefined}
    >
      Guides
    </a>
    <a
      href={recipesUrl}
      class:list={['nav-link', { 'nav-link--active': isRecipesPage }]}
      aria-current={isRecipesPage ? 'page' : undefined}
    >
      Recipes
    </a>
    <a
      href={apiUrl}
      class:list={['nav-link', { 'nav-link--active': isApiPage }]}
      aria-current={isApiPage ? 'page' : undefined}
    >
      API
    </a>
    <a
      href={changelogUrl}
      class:list={['nav-link', { 'nav-link--active': isChangelogPage }]}
      aria-current={isChangelogPage ? 'page' : undefined}
    >
      Changelog
    </a>
    <SupportDropdown />
    <!-- Headway changelog widget -->
    <button
      class="hw-badge-btn"
      id="hw-badge-cont"
      aria-label="What's new"
      type="button"
      title="What's new"
    >
      <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none">
        <path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <!-- GitHub stars badge -->
    <a
      href="https://github.com/handsontable/handsontable"
      class="github-stars"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Handsontable on GitHub"
      id="github-stars-link"
    >
      <svg aria-hidden="true" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
      </svg>
      <span class="github-stars__count" id="github-stars-count"></span>
    </a>
    <ThemeSelect />
    <LanguageSelect />
  </div>
</div>

<!-- Headway widget script -->
<script is:inline>
  window.HW_config = {
    selector: '#hw-badge-cont',
    account: 'xaD6ry',
  };
</script>
<script is:inline async src="https://cdn.headwayapp.co/widget.js"></script>

<!-- GitHub stars: fetch count client-side and inject into badge -->
<script>
  (async () => {
    try {
      const res = await fetch('https://api.github.com/repos/handsontable/handsontable');
      if (!res.ok) return;
      const data = await res.json();
      const count = data?.stargazers_count ?? 0;
      const formatted =
        Math.abs(count) > 999
          ? `${(Math.sign(count) * (Math.abs(count) / 1000)).toFixed(1)}k`
          : String(count);
      const el = document.getElementById('github-stars-count');
      if (el) el.textContent = formatted;
    } catch {
      // Network unavailable — badge stays empty
    }
  })();
</script>

<style>
  .header {
    gap: var(--sl-nav-gap);
    justify-content: space-between;
    align-items: center;
    height: 100%;
  }

  .title-wrapper {
    overflow: clip;
    padding: 0.25rem;
    margin: -0.25rem;
    min-width: 0;
  }

  .right-group {
    gap: 0.5rem;
    align-items: center;
  }

  /* Shared nav link style (Guides / Recipes / API / Changelog) */
  .nav-link {
    color: var(--sl-color-text);
    font-size: var(--sl-text-sm);
    font-weight: 600;
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border: 1px solid transparent;
    border-radius: 4px;
    transition: color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--sl-color-accent);
    border-color: var(--sl-color-accent);
  }

  .nav-link--active {
    color: var(--sl-color-accent);
    border-color: var(--sl-color-accent);
  }

  /* Headway bell button */
  .hw-badge-btn {
    background: none;
    border: none;
    border-radius: 4px;
    color: var(--sl-color-text);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem;
    position: relative;
    transition: color 0.15s;
  }

  .hw-badge-btn:hover {
    color: var(--sl-color-accent);
  }

  /* GitHub stars badge */
  .github-stars {
    align-items: center;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 4px;
    color: var(--sl-color-text);
    display: inline-flex;
    font-size: var(--sl-text-sm);
    font-weight: 600;
    gap: 0.35rem;
    padding: 0.25rem 0.5rem;
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }

  .github-stars:hover {
    color: var(--sl-color-accent);
    border-color: var(--sl-color-accent);
  }

  .github-stars__count:empty {
    display: none;
  }

  @media (min-width: 50rem) {
    :global(:root[data-has-sidebar]) {
      --__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
    }
    :global(:root:not([data-has-toc])) {
      --__toc-width: 0rem;
    }

    .header {
      --__sidebar-width: max(0rem, var(--sl-content-inline-start, 0rem) - var(--sl-nav-pad-x));
      --__main-column-fr: calc(
        (
          100% + var(--__sidebar-pad, 0rem) - var(--__toc-width, var(--sl-sidebar-width)) -
            (2 * var(--__toc-width, var(--sl-nav-pad-x))) - var(--sl-content-inline-start, 0rem) -
            var(--sl-content-width)
        ) / 2
      );
      display: grid;
      grid-template-columns:
        minmax(
          calc(var(--__sidebar-width) + max(0rem, var(--__main-column-fr) - var(--sl-nav-gap))),
          auto
        )
        1fr
        auto;
      align-content: center;
    }
  }
</style>
