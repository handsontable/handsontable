---
/**
 * "What's new" info banner shown at the top of the sidebar.
 *
 * Mirrors the VuePress InfoBox.vue component:
 *  - Displays "What's new in {version}" with a "Learn more" link to the
 *    changelog anchor for that version.
 *  - Dismissible: clicking ✕ saves the version to localStorage so the banner
 *    stays hidden until a new version is released.
 *  - Rendered server-side; show/hide logic is handled client-side via the
 *    inline script below.
 *
 * @prop {string} prefix - Active framework prefix, e.g. 'javascript-data-grid'
 */

import { createRequire } from 'module';
import { dirname, join } from 'path';
import { fileURLToPath } from 'url';

const { prefix } = Astro.props;

const __dirname = dirname(fileURLToPath(import.meta.url));
const require = createRequire(import.meta.url);

// Read the patch version from the core package (e.g. "17.0.0").
let hotVersion = '';

try {
  const pkg = require(join(__dirname, '../../..', 'handsontable', 'package.json'));

  hotVersion = pkg.version ?? '';
} catch {
  // Fallback: leave empty — the banner will not render.
}

// Changelog anchor: "17.0.0" → "#_17-0-0"
const changelogAnchor = hotVersion ? `#_${hotVersion.replaceAll('.', '-')}` : '';
const changelogUrl = `/${prefix}/changelog/${changelogAnchor}`;
---

{hotVersion && (
  <div
    class="hot-infobox"
    id="hot-infobox"
    data-version={hotVersion}
    hidden
  >
    <span class="hot-infobox__icon" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
      </svg>
    </span>

    <div class="hot-infobox__body">
      <p class="hot-infobox__title">What's new in {hotVersion}</p>
      <a href={changelogUrl} class="hot-infobox__link">
        Learn more
        <span class="sl-visually-hidden"> about version {hotVersion}</span>
      </a>
    </div>

    <button
      type="button"
      class="hot-infobox__close"
      aria-label="Dismiss what's new banner"
      id="hot-infobox-close"
    >
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M1 1l12 12M13 1L1 13"/>
      </svg>
    </button>
  </div>
)}

<script>
  const box     = document.getElementById('hot-infobox');
  const closeBtn = document.getElementById('hot-infobox-close');

  if (box) {
    const version = box.dataset.version ?? '';
    const stored  = localStorage.getItem('hotDocsVersion');

    // Show only when the stored version differs from the current one.
    if (stored !== version) {
      box.hidden = false;
      box.classList.add('is-visible');
    }

    if (closeBtn) {
      closeBtn.addEventListener('click', () => {
        box.classList.remove('is-visible');
        // After CSS transition ends, hide fully.
        box.addEventListener('transitionend', () => {
          box.hidden = true;
        }, { once: true });
        localStorage.setItem('hotDocsVersion', version);
      });
    }
  }
</script>

<style>
  .hot-infobox {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    margin: 0.75rem 0.5rem 0.25rem;
    padding: 0.65rem 0.75rem;
    border-radius: 6px;
    background: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 30%, transparent);

    /* Slide-in animation (hidden → visible) */
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .hot-infobox.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .hot-infobox__icon {
    flex-shrink: 0;
    color: var(--sl-color-accent);
    margin-top: 0.05rem;
  }

  .hot-infobox__body {
    flex: 1;
    min-width: 0;
  }

  .hot-infobox__title {
    margin: 0 0 0.2rem;
    font-size: var(--sl-text-sm);
    font-weight: 600;
    color: var(--sl-color-text);
    line-height: 1.3;
  }

  .hot-infobox__link {
    font-size: var(--sl-text-xs);
    color: var(--sl-color-accent);
    text-decoration: none;
    font-weight: 500;
  }

  .hot-infobox__link:hover {
    text-decoration: underline;
  }

  .hot-infobox__close {
    flex-shrink: 0;
    background: none;
    border: none;
    color: var(--sl-color-gray-3);
    cursor: pointer;
    padding: 0.1rem;
    border-radius: 3px;
    line-height: 0;
    transition: color 0.15s;
    margin-top: 0.05rem;
  }

  .hot-infobox__close:hover {
    color: var(--sl-color-text);
  }
</style>
