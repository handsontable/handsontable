{
  "name": "handsontable-documentation",
  "private": true,
  "version": "0.0.0",
  "description": "Handsontable documentation",
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev":                          "astro dev",
    "start":                        "astro dev",
    "build":                        "astro build",
    "preview":                      "astro preview",
    "docs:lint":                    "eslint --ext .js,.mjs,.ts,.astro src content",
    "docs:lint:fix":                "eslint --ext .js,.mjs,.ts,.astro src content --fix",
    "docs:api":                     "node .vuepress/tools/jsdoc-convert/index.mjs",
    "docs:check-links":             "node .vuepress/tools/check-links.js",
    "docs:code-examples:generate-js":     "bash .vuepress/tools/code-examples-generator.sh",
    "docs:code-examples:generate-all-js": "bash .vuepress/tools/code-examples-generator.sh --generateAll",
    "docs:code-examples:format-all-ts":   "bash .vuepress/tools/code-examples-generator.sh --formatAllTsExamples",
    "docs:review":                  "./.vuepress/tools/review-commit.sh",
    "docs:test:example-checker":    "node .vuepress/tools/example-checker",
    "docs:visual-test":             "npx playwright test",
    "docs:visual-test:update-screenshot": "npx playwright test -u"
  },
  "license": "CC BY 4.0",
  "dependencies": {
    "astro":              "^5.0.0",
    "@astrojs/starlight": "^0.32.0",
    "dotenv":             "^16.4.5",
    "dayjs":              "^1.11.10",
    "gray-matter":        "^4.0.3",
    "unist-util-visit":   "^5.0.0"
  },
  "devDependencies": {
    "typescript":              "^5.4.0",
    "@types/node":             "^20.11.27",
    "eslint":                  "^8.57.0",
    "cross-env":               "^7.0.3",
    "chalk":                   "^4.1.1",
    "fs-extra":                "^9.1.0",
    "glob":                    "^7.2.0",
    "rimraf":                  "^3.0.2",
    "semver":                  "^5.7.1",
    "jsdoc-to-markdown":       "^7.0.1",
    "dmd":                     "^6.0.0",
    "broken-link-checker":     "^0.7.8",
    "@octokit/rest":           "^18.6.7",
    "inquirer":                "^8.1.1",
    "@playwright/test":        "1.45.x"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ]
}
