{
  "name": "handsontable-documentation",
  "private": true,
  "version": "0.0.0",
  "description": "Handsontable documentation",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "docs:api": "node scripts/jsdoc-convert/index.mjs",
    "docs:code-examples:generate-js": "node scripts/transpile-doc-example.mjs",
    "build": "npm run docs:api && astro build",
    "preview": "astro preview",
    "docs:test:plugins": "node --test src/plugins/__tests__/*.test.mjs src/lib/__tests__/*.test.mjs",
    "docs:lint": "eslint --ext .js,.mjs,.ts,.astro src content",
    "docs:lint:fix": "eslint --ext .js,.mjs,.ts,.astro src content --fix",
    "docs:docker:build:production": "cross-env BUILD_MODE=production npm run build && docker build -f docker/Dockerfile -t docs-md:production .",
    "docs:visual-test": "npx playwright test",
    "docs:visual-test:update-screenshot": "npx playwright test -u"
  },
  "license": "CC BY 4.0",
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/starlight": "^0.38.2",
    "@astrojs/starlight-docsearch": "^0.7.0",
    "@expressive-code/plugin-collapsible-sections": "^0.41.7",
    "@expressive-code/plugin-line-numbers": "^0.41.7",
    "@handsontable/pikaday": "^1.0.0",
    "@simonwep/pickr": "^1.9.1",
    "astro": "^6.1.1",
    "chart.js": "^4.5.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.10",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "flatpickr": "^4.6.13",
    "gray-matter": "^4.0.3",
    "hyperformula": "^3.2.0",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.7",
    "numbro": "^2.5.0",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-colorful": "^5.6.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "react-redux": "^9.2.0",
    "react-star-rating-component": "^1.4.1",
    "redux": "^5.0.1",
    "remark-gfm": "^4.0.0",
    "shiki": "^1.22.0",
    "starlight-page-actions": "^0.5.0",
    "starlight-theme-rapide": "^0.5.2",
    "unist-util-visit": "^5.0.0",
    "pinia": "^2.3.1",
    "vuex": "^4.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@octokit/rest": "^18.6.7",
    "@playwright/test": "1.45.x",
    "@types/node": "^20.11.27",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "^3.5.35",
    "broken-link-checker": "^0.7.8",
    "chalk": "^4.1.1",
    "cross-env": "^7.0.3",
    "dmd": "^6.0.0",
    "eslint": "^8.57.0",
    "execa": "^5.1.1",
    "fs-extra": "^9.1.0",
    "glob": "^7.2.0",
    "inquirer": "^8.1.1",
    "jsdoc-to-markdown": "^7.0.1",
    "rimraf": "^3.0.2",
    "semver": "^5.7.1",
    "typescript": "^5.4.0",
    "vite": "^7.3.2"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ]
}
