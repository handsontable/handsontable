{
  "name": "handsontable",
  "description": "Handsontable is a JavaScript Data Grid available for React, Angular and Vue.",
  "homepage": "https://handsontable.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/handsontable/handsontable.git"
  },
  "bugs": {
    "url": "https://github.com/handsontable/handsontable/issues"
  },
  "author": "Handsoncode <hello@handsontable.com>",
  "version": "17.1.0",
  "main": "index",
  "module": "index.mjs",
  "jsnext:main": "index.mjs",
  "jsdelivr": "dist/handsontable.full.min.js",
  "unpkg": "dist/handsontable.full.min.js",
  "scripts": {
    "typecheck": "node scripts/run.mjs typecheck",
    "clean": "node scripts/run.mjs clean",
    "lint": "node scripts/run.mjs --parallel lint",
    "lint:fix": "node scripts/run.mjs --sequential lint:fix",
    "eslint": "node scripts/run.mjs lint:eslint",
    "eslint:fix": "node scripts/run.mjs lint:eslint.fix",
    "stylelint": "node scripts/run.mjs lint:stylelint",
    "stylelint:fix": "node scripts/run.mjs lint:stylelint.fix",
    "measure:module-sizes": "node scripts/run.mjs measure:module-sizes",
    "test": "node scripts/run.mjs --sequential test",
    "test.random": "node scripts/run.mjs --sequential test -- --random",
    "test:walkontable": "node scripts/run.mjs --sequential test:walkontable",
    "test:walkontable.random": "node scripts/run.mjs --sequential test:walkontable -- --random",
    "test:walkontable.watch": "node scripts/run.mjs test:walkontable.watch",
    "test:walkontable.dump": "node scripts/run.mjs test:walkontable.dump",
    "test:walkontable.puppeteer": "node scripts/run.mjs test:walkontable.puppeteer",
    "test:production": "node scripts/run.mjs --sequential test:production",
    "test:production.random": "node scripts/run.mjs --sequential test:production -- --random",
    "test:production.dump": "node scripts/run.mjs test:production.dump",
    "test:e2e": "node scripts/run.mjs --sequential test:e2e",
    "test:e2e.random": "node scripts/run.mjs --sequential test:e2e -- --random",
    "test:e2e.verbose": "node scripts/run.mjs --sequential test:e2e -- --verbose",
    "test:e2e.watch": "node scripts/run.mjs test:e2e.watch",
    "test:e2e.dump": "node scripts/run.mjs test:e2e.dump",
    "test:e2e.dump.esm-cjs": "node scripts/run.mjs test:e2e.dump.esm-cjs",
    "test:e2e.puppeteer": "node scripts/run.mjs test:e2e.puppeteer",
    "test:unit": "node scripts/run.mjs --sequential test:unit",
    "test:unit.jest": "node scripts/run.mjs test:unit.jest",
    "test:unit.watch": "node scripts/run.mjs --sequential test:unit -- --watch",
    "test:mobile.dump": "node scripts/run.mjs test:mobile.dump",
    "test:types": "node scripts/run.mjs test:types",
    "watch": "node scripts/run.mjs --sequential watch",
    "build": "node scripts/run.mjs --parallel build",
    "postbuild": "node scripts/run.mjs prepare-package-for-publish",
    "build:sequential": "node scripts/run.mjs --sequential build",
    "build:commonjs": "node scripts/run.mjs build:commonjs",
    "build:es": "node scripts/run.mjs build:es",
    "build:umd": "node scripts/run.mjs build:umd",
    "build:umd-from-esm": "node scripts/run.mjs build:umd-from-esm",
    "build:umd-from-cjs": "node scripts/run.mjs build:umd-from-cjs",
    "build:umd.min": "node scripts/run.mjs build:umd.min",
    "build:styles": "node scripts/run.mjs build:styles",
    "build:styles.min": "node scripts/run.mjs build:styles.min",
    "build:themes-css": "node scripts/run.mjs build:themes-css",
    "build:themes-css.min": "node scripts/run.mjs build:themes-css.min",
    "build:themes-umd": "node scripts/run.mjs build:themes-umd",
    "build:themes-umd.min": "node scripts/run.mjs build:themes-umd.min",
    "build:types": "node scripts/run.mjs build:types",
    "build:walkontable": "node scripts/run.mjs build:walkontable",
    "build:languages": "node scripts/run.mjs build:languages",
    "build:languages.es": "node scripts/run.mjs build:languages.es",
    "build:languages.min": "node scripts/run.mjs build:languages.min",
    "publish-package": "cd tmp && npm publish",
    "create-package": "cd tmp && npm pack"
  },
  "keywords": [
    "data",
    "grid",
    "table",
    "editor",
    "grid-editor",
    "data-grid",
    "data-table",
    "spreadsheet",
    "excel",
    "tabular-data",
    "edit-cell",
    "editable-table",
    "data-spreadsheet"
  ],
  "dependencies": {},
  "devDependencies": {
    "@babel/core": "^7.11.4",
    "@babel/eslint-parser": "^7.13.14",
    "@babel/eslint-plugin": "^7.13.16",
    "@babel/plugin-transform-runtime": "^7.11.0",
    "@babel/preset-env": "^7.11.0",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/register": "^7.8.3",
    "@babel/runtime": "^7.11.2",
    "@rspack/cli": "^1.7.11",
    "@rspack/core": "^1.7.11",
    "@swc/core": "^1.15.26",
    "@swc/helpers": "^0.5.21",
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "babel-jest": "^27.5.1",
    "babel-plugin-transform-inline-environment-variables": "^0.4.3",
    "chalk": "^4.1.2",
    "concurrently": "^6.4.0",
    "cross-env": "^7.0.3",
    "css-loader": "6.10.0",
    "env-cmd": "^9.0.3",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-compat": "^4.2.0",
    "eslint-plugin-handsontable": "file:.config/plugin/eslint",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^46.0.0",
    "exceljs": "^4.4.0",
    "execa": "^5.0.0",
    "fs-extra": "^4.0.2",
    "glob": "^7.1.2",
    "global-jsdom": "^24.0.0",
    "html-parse-stringify": "^3.0.1",
    "http-server": "^14.1.1",
    "hyperformula": "^3.0.0",
    "jasmine-co": "^1.2.2",
    "jasmine-console-reporter": "^3.1.0",
    "jasmine-core": "^3.4.0",
    "jasmine-terminal-reporter": "^1.0.3",
    "jest": "^27.5.1",
    "jest-cli": "^27.5.1",
    "jest-environment-jsdom": "^27.5.1",
    "jest-matcher-utils": "^27.5.1",
    "jsdom": "^24.0.0",
    "loader-utils": "^1.4.2",
    "lodash": "^4.17.20",
    "lodash.debounce": "^4.0.8",
    "minimatch": "^3.0.4",
    "puppeteer": "^24.2.1",
    "replace-in-file": "^6.1.0",
    "rimraf": "^3.0.2",
    "sass": "^1.58.0",
    "sass-loader": "^10.4.1",
    "string-replace-loader": "^3.1.0",
    "stylelint": "^16.3.1",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-config-standard-scss": "^13.1.0",
    "typescript": "^6.0.0"
  },
  "license": "SEE LICENSE IN LICENSE.txt",
  "typings": "./index.d.ts",
  "resolutions": {
    "@babel/core": "^7.11.4"
  },
  "handsontable": {
    "copy": [
      "dist/handsontable.full.js",
      "dist/handsontable.full.min.js",
      "dist/handsontable.js",
      "dist/handsontable.min.js",
      "dist/languages",
      "dist/themes",
      "styles",
      "languages",
      "../CHANGELOG.md",
      "../handsontable-non-commercial-license.pdf",
      "../LICENSE.txt",
      "README.md"
    ],
    "exports": [
      "./cellTypes/*/+(index)*",
      "./cellTypes/+(index|registry)*",
      "./languages/!(all.js)",
      "./editors/*/+(index)*",
      "./editors/+(index|registry|factory)*",
      "./plugins/*/+(index)*",
      "./plugins/+(index|registry)*",
      "./renderers/*/+(index)*",
      "./renderers/+(index|registry|factory)*",
      "./validators/*/+(index)*",
      "./validators/+(index|registry)*",
      "./i18n/+(index|registry)*",
      "./i18n/languages/*",
      "./dist/**/*.+(js|css)",
      "./styles/**/*.+(css)",
      "./themes/+(index|registry)*",
      "./themes/static/variables/**/*",
      {
        ".": {
          "types": "./index.d.ts",
          "import": "./index.mjs",
          "require": "./index.js"
        }
      },
      {
        "./base": {
          "types": "./base.d.ts",
          "import": "./base.mjs",
          "require": "./base.js"
        }
      },
      {
        "./languages/all": {
          "import": "./languages/index.mjs",
          "require": "./languages/all.js"
        }
      },
      {
        "./registry": {
          "types": "./registry.d.ts",
          "import": "./registry.mjs",
          "require": "./registry.js"
        }
      },
      {
        "./settings": {
          "types": "./settings.d.ts",
          "import": "./settings.mjs",
          "require": "./settings.js"
        }
      },
      {
        "./themes": {
          "types": "./themes/index.d.ts",
          "import": "./themes/index.mjs",
          "require": "./themes/index.js"
        }
      }
    ],
    "fields": [
      "name",
      "description",
      "homepage",
      "repository",
      "bugs",
      "author",
      "version",
      "main",
      "module",
      "jsnext:main",
      "jsdelivr",
      "unpkg",
      "keywords",
      "dependencies",
      "optionalDependencies",
      "license",
      "sideEffects"
    ]
  },
  "sideEffects": [
    "**/*.css",
    "./languages/*",
    "./plugins/filters/condition/**",
    "./plugins/filters/logicalOperations/**"
  ],
  "publishConfig": {
    "directory": "tmp",
    "linkDirectory": true
  }
}
